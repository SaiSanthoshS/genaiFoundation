PORT=3000

# Get a key at https://console.anthropic.com/
# Used server-side only, for classifying custom (non-curated) book titles
# into themes/pages/author via the Claude API. If omitted, the app still
# works, but custom books fall back to generic placeholder metadata.
ANTHROPIC_API_KEY=

# Optional: override the model used for metadata lookups
CLAUDE_MODEL=claude-sonnet-5
